# ============================================================
# Rezus ICP Discovery : Template des variables d'environnement
# Copie ce fichier en `.env.local` et remplis les valeurs.
# `.env.local` n'est jamais committé (cf .gitignore).
# ============================================================

# --- LLM & recherche ---------------------------------------
# Anthropic Claude API : https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
# Linkup (recherche FR primaire) : https://app.linkup.so → API Keys
LINKUP_API_KEY=
# Tavily (recherche fallback) : https://app.tavily.com → API Keys
TAVILY_API_KEY=
# OpenAI (speech-to-text dictée vocale) : https://platform.openai.com → API Keys
OPENAI_API_KEY=

# --- Supabase (authentification) ---------------------------
# Dashboard > ton projet > Settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=
# Clé "Publishable" (sb_publishable_...). Remplace l'ancienne clé "anon".
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Clé "Secret" (sb_secret_...). Remplace "service_role".
# Serveur uniquement, ne jamais exposer cote client.
SUPABASE_SECRET_KEY=
